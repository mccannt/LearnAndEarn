// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Child user (the learner)
model Child {
  id            String    @id @default(cuid())
  name          String
  age           Int
  gradeLevel    Int?
  avatarUrl     String?   @default("/default-avatar.png")
  totalPoints   Int       @default(0)
  currentStreak Int       @default(0)
  longestStreak Int       @default(0)
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
  parentId      String
  parent        Parent    @relation(fields: [parentId], references: [id], onDelete: Cascade)
  
  // Equipped Avatar Items
  equippedHairStyle   String? @default("hair1")
  equippedShirt       String? @default("shirt1")
  equippedPants       String? @default("pants1")
  equippedShoes       String? @default("shoes1")
  equippedAccessory   String? @default("none")
  equippedBackground  String? @default("bg1")

  learningSessions LearningSession[]
  progress         Progress[]
  rewards          Reward[]
  unlockedItems    UnlockedItem[]

  @@map("children")
}

model UnlockedItem {
  id         String   @id @default(cuid())
  childId    String
  child      Child    @relation(fields: [childId], references: [id])
  itemId     String
  item       AvatarItemCatalog @relation(fields: [itemId], references: [id], onDelete: Cascade)
  unlockedAt DateTime @default(now())

  @@unique([childId, itemId]) // A child can only unlock an item once
  @@map("unlocked_items")
}

model AvatarItemCatalog {
  id           String            @id
  name         String
  type         AvatarItemType
  color        String
  cost         Int
  rarity       AvatarItemRarity
  isDefault    Boolean           @default(false)
  isActive     Boolean           @default(true)
  sortOrder    Int               @default(0)
  createdAt    DateTime          @default(now())
  updatedAt    DateTime          @updatedAt
  unlockedItems UnlockedItem[]

  @@map("avatar_item_catalog")
}

// Parent user
model Parent {
  id            String   @id @default(cuid())
  name          String
  email         String   @unique
  password      String   // In production, this should be hashed
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  // Relationships
  children      Child[]
  settings      Settings[]
  
  @@map("parents")
}

// Learning session tracking
model LearningSession {
  id              String   @id @default(cuid())
  childId         String
  subject         Subject  // MATH or ENGLISH
  topic           String   // e.g., "multiplication", "grammar"
  duration        Int      // in minutes
  questionsAsked  Int      @default(0)
  questionsCorrect Int     @default(0)
  pointsEarned    Int      @default(0)
  completedAt     DateTime @default(now())
  
  // Relationships
  child           Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  
  @@map("learning_sessions")
}

// Subject enum
enum Subject {
  MATH
  ENGLISH
}

// Progress tracking per topic
model Progress {
  id          String   @id @default(cuid())
  childId     String
  subject     Subject
  topic       String
  level       Int      @default(1)
  accuracy    Float    @default(0.0) // 0.0 to 1.0
  totalQuestions Int   @default(0)
  correctAnswers Int  @default(0)
  lastPracticed DateTime @default(now())
  
  // Relationships
  child       Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  
  @@unique([childId, subject, topic])
  @@map("progress")
}

// Reward system
model Reward {
  id            String   @id @default(cuid())
  childId       String
  catalogItemId String?
  type          RewardType
  amount        Int      // total points spent
  quantity      Int      @default(1)
  rewardValue   Int?
  description   String
  earnedAt      DateTime @default(now())
  redeemedAt    DateTime?
  isRedeemed    Boolean  @default(false)
  
  // Relationships
  child         Child    @relation(fields: [childId], references: [id], onDelete: Cascade)
  catalogItem   RewardCatalog? @relation(fields: [catalogItemId], references: [id], onDelete: SetNull)
  
  @@map("rewards")
}

model RewardCatalog {
  id             String      @id
  type           RewardType
  title          String
  description    String
  cost           Int
  rewardValue    Int
  isActive       Boolean     @default(true)
  stockTotal     Int?
  stockRemaining Int?
  sortOrder      Int         @default(0)
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt
  rewards        Reward[]

  @@map("reward_catalog")
}

// Reward type enum
enum RewardType {
  POINTS
  SCREEN_TIME_MINUTES
  ROBLOX_CREDITS
}

enum AvatarItemType {
  HAIR_STYLE
  SHIRT
  PANTS
  SHOES
  ACCESSORY
  BACKGROUND
}

enum AvatarItemRarity {
  COMMON
  RARE
  EPIC
  LEGENDARY
}

// Parent settings and controls
model Settings {
  id                    String   @id @default(cuid())
  parentId              String
  maxDailySessionTime   Int      @default(60) // in minutes
  maxWeeklySessionTime  Int      @default(300) // in minutes
  pointsPerScreenTime   Int      @default(10) // points needed for 1 minute of screen time
  pointsPerRobux        Int      @default(100) // points needed for 1 Robux
  sessionDifficulty     String   @default("medium") // easy, medium, hard
  passwordProtected     Boolean  @default(true)
  parentPassword        String?  // for accessing parent dashboard
  
  // Relationships
  parent                Parent   @relation(fields: [parentId], references: [id], onDelete: Cascade)
  
  @@map("settings")
}

// Math questions database
model MathQuestion {
  id                 String   @id @default(cuid())
  seedKey            String?  @unique
  question           String
  answer             Float
  remainder          Int?
  operation          MathOperation
  difficulty         Int      @default(1) // 1-5
  topic              String   // e.g., "multiplication", "division"
  gradeMin           Int?
  gradeMax           Int?
  curriculumCode     String?
  curriculumOutcome  String?
  curriculumSourceUrl String?
  
  @@map("math_questions")
}

// Math operation enum
enum MathOperation {
  ADDITION
  SUBTRACTION
  MULTIPLICATION
  DIVISION
}

// English questions database
model EnglishQuestion {
  id                 String   @id @default(cuid())
  seedKey            String?  @unique
  question           String
  options            String   // JSON array of options
  correctAnswer      String
  questionType       EnglishQuestionType
  difficulty         Int      @default(1) // 1-5
  topic              String   // e.g., "grammar", "reading_comprehension"
  gradeMin           Int?
  gradeMax           Int?
  curriculumCode     String?
  curriculumOutcome  String?
  curriculumSourceUrl String?
  
  @@map("english_questions")
}

// English question type enum
enum EnglishQuestionType {
  GRAMMAR
  VOCABULARY
  READING_COMPREHENSION
  SENTENCE_STRUCTURE
}
